# =============================================================================
# ZERO AI - Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in your API keys
# Get free API keys from the providers listed below
# =============================================================================

# ─── SUPABASE (Required for auth & database) ─────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── REDIS (Optional - for rate limiting & caching) ──────────────────────────
UPSTASH_REDIS_REST_URL=your-upstash-redis-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# ─── ASTRA DB (Optional - for vector memory) ─────────────────────────────────
ASTRA_DB_NAMESPACE=default_keyspace
ASTRA_DB_COLLECTION=zero_memories
ASTRA_DB_API_ENDPOINT=your-astra-db-endpoint
ASTRA_DB_APPLICATION_TOKEN=your-astra-db-token

# ─── GEMINI API KEYS (For App Factory & Zero Live) ───────────────────────────
# Get free keys at: https://aistudio.google.com/apikey
GEMINI_FLASH_KEY_1=your-gemini-key-1
GEMINI_FLASH_KEY_2=your-gemini-key-2
GEMINI_FLASH_KEY_3=your-gemini-key-3
GEMINI_FLASH_KEY_4=your-gemini-key-4

# Gemini 2.5 Flash (Premium - for App Factory)
GEMINI_2_5_FLASH_KEY_1=your-gemini-2-5-key-1
GEMINI_2_5_FLASH_KEY_2=your-gemini-2-5-key-2

# ─── GITHUB MODELS (Free GPT-4o access) ──────────────────────────────────────
# Get free tokens at: https://github.com/marketplace/models
GITHUB_TOKEN_1=your-github-token-1
GITHUB_TOKEN_2=your-github-token-2

# ─── CEREBRAS (Ultra-fast inference) ─────────────────────────────────────────
# Get free keys at: https://cloud.cerebras.ai/
CEREBRAS_API_KEY_1=your-cerebras-key-1
CEREBRAS_API_KEY_2=your-cerebras-key-2
CEREBRAS_API_KEY_3=your-cerebras-key-3
CEREBRAS_API_KEY_4=your-cerebras-key-4

# ─── FIREWORKS AI (High-quality models) ──────────────────────────────────────
# Get free keys at: https://fireworks.ai/
FIREWORKS_API_KEY_1=your-fireworks-key-1
FIREWORKS_API_KEY_2=your-fireworks-key-2
FIREWORKS_API_KEY_3=your-fireworks-key-3
FIREWORKS_API_KEY_4=your-fireworks-key-4
FIREWORKS_API_KEY_5=your-fireworks-key-5
FIREWORKS_API_KEY_6=your-fireworks-key-6

# ─── SILICONFLOW (Additional fallback) ───────────────────────────────────────
# Get free keys at: https://siliconflow.cn/
SILICONFLOW_API_KEY_1=your-siliconflow-key-1
SILICONFLOW_API_KEY_2=your-siliconflow-key-2
SILICONFLOW_API_KEY_3=your-siliconflow-key-3
SILICONFLOW_API_KEY_4=your-siliconflow-key-4
SILICONFLOW_API_KEY_5=your-siliconflow-key-5
SILICONFLOW_API_KEY_6=your-siliconflow-key-6

# ─── OPENROUTER (Fallback for free models) ───────────────────────────────────
# Get free keys at: https://openrouter.ai/
OPENROUTER_API_KEY_1=your-openrouter-key-1
OPENROUTER_API_KEY_2=your-openrouter-key-2

# ─── TAVILY (Web search) ─────────────────────────────────────────────────────
# Get free key at: https://tavily.com/
TAVILY_API_KEY=your-tavily-api-key

# ─── IMAGE GENERATION ────────────────────────────────────────────────────────
# Together AI - Flux Schnell (free tier)
TOGETHER_API_KEY=your-together-api-key

# ─── ZERO LIVE API KEY (For real-time voice) ─────────────────────────────────
# Uses Gemini Live API - same keys as above work
GEMINI_LIVE_API_KEY=your-gemini-key-for-live

# ─── PAYMENTS (Optional) ─────────────────────────────────────────────────────
# Razorpay (India)
RAZORPAY_KEY_ID=your-razorpay-key
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# Stripe (International)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# ─── APP CONFIG ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_AGENT_WS_URL=ws://localhost:7821
