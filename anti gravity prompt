import { TEMPLATES, TemplateKey } from "./templates"
import { streamWithFallback } from "@/lib/providers/router"

async function classifyTemplate(description: string): Promise<TemplateKey> {
  const res = await fetch(
    `https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${process.env.GEMINI_KEY}`,
    {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        contents: [{
          parts: [{
            text: `Which template fits this request? Reply with ONLY one word from this list:
landing, dashboard, tool, game

Request: "${description}"
Answer:`
          }]
        }],
        generationConfig: { maxOutputTokens: 10 }
      })
    }
  )
  const data = await res.json()
  const answer = data.candidates?.[0]?.content?.parts?.[0]?.text?.trim().toLowerCase()
  const valid: TemplateKey[] = ["landing", "dashboard", "tool", "game"]
  return valid.includes(answer as TemplateKey) ? answer as TemplateKey : "landing"
}

async function customizeFile(
  filename: string,
  baseContent: string,
  description: string
): Promise<{ filename: string; content: string }> {

  const isCSS = filename.endsWith(".css")
  const isJS = filename.endsWith(".js")
  const isHTML = filename.endsWith(".html")

  const instructions = isHTML
    ? "Update content, copy, headings, and structure to match the description. Keep all HTML structure and script/style links."
    : isCSS
    ? "Update colors, gradients, and theme to match the app's purpose. Make it visually stunning with modern effects."
    : "Implement real working functionality for this specific app. Replace placeholder logic with actual working code."

  const res = await fetch(
    `https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${process.env.GEMINI_KEY}`,
    {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        contents: [{
          parts: [{
            text: `You are customizing a ${filename} file for this app: "${description}"

Instructions: ${instructions}
Return ONLY the raw file content. No markdown. No backticks. No explanation.

Base file to modify:
${baseContent}`
          }]
        }],
        generationConfig: { maxOutputTokens: 2048 }
      })
    }
  )
  const data = await res.json()
  const content = data.candidates?.[0]?.content?.parts?.[0]?.text
    ?.replace(/^```[a-z]*\n?/gm, "")
    ?.replace(/```$/gm, "")
    ?.trim() || baseContent

  return { filename, content }
}

function buildStackBlitzUrl(files: { filename: string; content: string }[]): string {
  const fileObj: Record<string, string> = {}
  files.forEach(f => { fileObj[f.filename] = f.content })
  const encoded = Buffer.from(JSON.stringify(fileObj)).toString("base64")
  return `https://stackblitz.com/run?view=preview&title=Zero+App&files=${encodeURIComponent(encoded)}`
}

export async function buildApp(description: string): Promise<{
  files: { filename: string; content: string }[]
  stackblitzUrl: string
  template: string
}> {
  const templateKey = await classifyTemplate(description)
  const template = TEMPLATES[templateKey]

  // Customize all files in parallel
  const customizedFiles = await Promise.all(
    Object.entries(template.files).map(([filename, baseContent]) =>
      customizeFile(filename, baseContent, description)
    )
  )

  const stackblitzUrl = buildStackBlitzUrl(customizedFiles)

  return {
    files: customizedFiles,
    stackblitzUrl,
    template: templateKey
  }
}

