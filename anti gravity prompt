export async function pingAllSpaces() {
  const results = []
  
  for (const [tier, spaces] of Object.entries(HF_SPACES)) {
    for (const spaceId of spaces) {
      const url = `https://${spaceId?.replace("/", "-")}.hf.space`
      const redisKey = `hf:space:${spaceId}:status`
      
      try {
        const start = Date.now()
        const res = await fetch(`${url}/`, {
          signal: AbortSignal.timeout(8000),
          method: "HEAD"
        })
        const latency = Date.now() - start
        
        if (res.ok || res.status === 200) {
          await redis.set(redisKey, "awake", { ex: 300 })
          await redis.set(`hf:space:${spaceId}:latency`, latency)
          results.push({ space: spaceId, status: "awake", latency })
        } else if (res.status === 503) {
          // Space sleeping — wake it
          await redis.set(redisKey, "waking", { ex: 120 })
          fetch(`${url}/api/predict`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ data: ["ping"] })
          }).catch(() => {})
          results.push({ space: spaceId, status: "waking" })
        }
      } catch {
        await redis.set(redisKey, "sleeping", { ex: 60 })
        results.push({ space: spaceId, status: "sleeping" })
      }
    }
  }
  return results
}

