export async function* runAgent(goal: string): AsyncGenerator<{
  type: "plan" | "worker_start" | "worker_done" | "synthesis" | "done"
  data: any
}> {
  // Step 1: Create plan
  const plan = await createPlan(goal)
  yield { type: "plan", data: plan }

  // Step 2: Execute tasks respecting dependencies
  const results: Record<string, string> = {}
  const pending = [...plan.tasks]

  while (pending.length > 0) {
    // Find tasks whose dependencies are all satisfied
    const ready = pending.filter(t =>
      t.dependsOn.every(dep => dep in results)
    )
    if (ready.length === 0) break

    // Execute ready tasks in parallel
    yield { type: "worker_start", data: { tasks: ready.map(t => t.id) } }

    const taskResults = await Promise.allSettled(
      ready.map(async task => {
        const result = await executeTask(task)
        return { id: task.id, result }
      })
    )

    for (const r of taskResults) {
      if (r.status === "fulfilled") {
        results[r.value.id] = r.value.result
        yield { type: "worker_done", data: { taskId: r.value.id, result: r.value.result.slice(0, 200) } }
      }
    }

    // Remove completed tasks from pending
    ready.forEach(t => {
      const idx = pending.findIndex(p => p.id === t.id)
      if (idx > -1) pending.splice(idx, 1)
    })
  }

  // Step 3: Synthesize
  const finalResponse = await synthesize(goal, results)
  yield { type: "synthesis", data: finalResponse }
  yield { type: "done", data: null }
}

