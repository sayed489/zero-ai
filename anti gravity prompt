import { AgentTask, AgentPlan } from "./types"

const ORCHESTRATOR_PROMPT = `You are Zero's AI orchestrator — the CEO's brain.
Break the user's goal into parallel executable tasks.
Return ONLY valid JSON, no markdown, no explanation:
{
  "goal": "one sentence summary",
  "tasks": [
    {
      "id": "t1",
      "description": "what to do",
      "tool": "search|code|write|image|browse|vision|automate",
      "priority": 1,
      "input": "specific input for the tool",
      "dependsOn": []
    }
  ]
}

Tool capabilities:
- search: web search for information
- code: execute Python/JS code in sandbox
- write: generate text, reports, emails, content
- image: generate images
- browse: visit a URL and extract content
- vision: analyze an image or screenshot
- automate: trigger n8n workflow webhook`

async function createPlan(goal: string): Promise<AgentPlan> {
  const res = await fetch(
    `https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${process.env.GEMINI_KEY}`,
    {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        contents: [{ parts: [{ text: `${ORCHESTRATOR_PROMPT}\n\nUser goal: "${goal}"` }] }],
        generationConfig: { maxOutputTokens: 1024 }
      })
    }
  )
  const data = await res.json()
  const text = data.candidates?.[0]?.content?.parts?.[0]?.text || "{}"
  try {
    return JSON.parse(text.replace(/```json|```/g, "").trim())
  } catch {
    return { goal, tasks: [{ id: "t1", description: goal, tool: "write", priority: 1, input: goal, dependsOn: [], status: "pending" }] }
  }
}

async function executeTask(task: AgentTask): Promise<string> {
  switch (task.tool) {
    case "search": {
      const results = await search(task.input)
      return results.map(r => `${r.title}: ${r.snippet}`).join("\n")
    }
    case "code": {
      const res = await fetch("https://api.e2b.dev/sandboxes", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "X-API-Key": process.env.E2B_KEY!
        },
        body: JSON.stringify({
          template: "base",
          timeout: 30
        })
      })
      const sandbox = await res.json()
      const runRes = await fetch(`https://api.e2b.dev/sandboxes/${sandbox.sandboxId}/run`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "X-API-Key": process.env.E2B_KEY!
        },
        body: JSON.stringify({ code: task.input, language: "python" })
      })
      const runData = await runRes.json()
      return runData.stdout || runData.stderr || "Code executed"
    }
    case "write": {
      const res = await fetch("https://api.siliconflow.cn/v1/chat/completions", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Authorization": `Bearer ${process.env.SILICONFLOW_KEY_1}`
        },
        body: JSON.stringify({
          model: "Qwen/Qwen2.5-7B-Instruct",
          messages: [{ role: "user", content: task.input }],
          max_tokens: 1024
        })
      })
      const data = await res.json()
      return data.choices?.[0]?.message?.content || ""
    }
    case "image": {
      const result = await generateImage(task.input)
      return result.url
    }
    case "browse": {
      const res = await fetch(`https://r.jina.ai/${task.input}`, {
        headers: { "Accept": "text/plain" },
        signal: AbortSignal.timeout(15000)
      })
      const text = await res.text()
      return text.slice(0, 3000)
    }
    case "vision": {
      const res = await fetch(
        `https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${process.env.GEMINI_KEY}`,
        {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            contents: [{ parts: [{ text: task.input }] }],
            generationConfig: { maxOutputTokens: 1024 }
          })
        }
      )
      const data = await res.json()
      return data.candidates?.[0]?.content?.parts?.[0]?.text || ""
    }
    case "automate": {
      if (!process.env.N8N_WEBHOOK_URL) return "Automation webhook not configured"
      const res = await fetch(process.env.N8N_WEBHOOK_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ task: task.input, description: task.description })
      })
      return res.ok ? "Automation triggered successfully" : "Automation failed"
    }
    default:
      return "Unknown tool"
  }
}

async function synthesize(goal: string, results: Record<string, string>): Promise<string> {
  const context = Object.entries(results)
    .map(([id, result]) => `Task ${id} result: ${result}`)
    .join("\n\n")

  const res = await fetch("https://api.fireworks.ai/inference/v1/chat/completions", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      "Authorization": `Bearer ${process.env.FIREWORKS_KEY}`
    },
    body: JSON.stringify({
      model: "accounts/fireworks/models/qwen2p5-72b-instruct",
      messages: [
        {
          role: "system",
          content: "You are Zero AI. Synthesize the task results into a clear, comprehensive response for the user."
        },
        {
          role: "user",
          content: `Original goal: ${goal}\n\nTask results:\n${context}\n\nProvide a complete, helpful response:`
