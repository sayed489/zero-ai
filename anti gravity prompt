"use client"

import { useState, useEffect } from "react"

type NanoStatus = "unavailable" | "checking" | "loading" | "ready" | "error"

let engineRef: any = null

export function useNano() {
  const [status, setStatus] = useState<NanoStatus>("checking")
  const [progress, setProgress] = useState(0)

  useEffect(() => {
    initNano()
  }, [])

  async function initNano() {
    // Check WebGPU
    if (!navigator.gpu) {
      setStatus("unavailable")
      return
    }

    // Check if already cached
    const cached = localStorage.getItem("nano_ready")
    if (cached === "true" && engineRef) {
      setStatus("ready")
      return
    }

    setStatus("loading")

    try {
      const { CreateMLCEngine } = await import("@mlc-ai/web-llm")
      engineRef = await CreateMLCEngine("Qwen3-1.5B-Instruct-q4f16_1-MLC", {
        initProgressCallback: (p: any) => {
          setProgress(Math.round(p.progress * 100))
        }
      })
      localStorage.setItem("nano_ready", "true")
      setStatus("ready")

      window.dispatchEvent(new CustomEvent("nano-loaded"))
    } catch (e) {
      setStatus("error")
      localStorage.removeItem("nano_ready")
    }
  }

  async function chat(messages: { role: string; content: string }[]): Promise<ReadableStream | null> {
    if (!engineRef || status !== "ready") return null

    return new ReadableStream({
      async start(controller) {
        const reply = await engineRef.chat.completions.create({
          messages,
          stream: true,
          temperature: 0.7
        })
        for await (const chunk of reply) {
          const token = chunk.choices?.[0]?.delta?.content
          if (token) controller.enqueue(new TextEncoder().encode(token))
        }
        controller.close()
      }
    })
  }

  return { status, progress, chat, isReady: status === "ready" }
}

